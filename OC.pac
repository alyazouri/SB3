// ================= IPv6 HELPERS =================

function isIPv6(ip) {
  return ip && ip.indexOf(":") !== -1;
}

function padHextet(h) {
  h = (h || "").toLowerCase();
  while (h.length < 4) h = "0" + h;
  return h;
}

function expandIPv6(ip) {
  ip = (ip || "").toLowerCase();

  if (!ip || ip.indexOf(":") === -1)
    return null;

  var parts = ip.split("::");
  if (parts.length > 2)
    return null;

  var left = parts[0] ? parts[0].split(":") : [];
  var right = (parts.length === 2 && parts[1]) ? parts[1].split(":") : [];

  if (parts.length === 1 && left.length !== 8)
    return null;

  var missing = 8 - (left.length + right.length);
  if (missing < 0)
    return null;

  var full = [];
  var i;

  for (i = 0; i < left.length; i++) {
    if (left[i] === "") continue;
    full.push(padHextet(left[i]));
  }

  for (i = 0; i < missing; i++) {
    full.push("0000");
  }

  for (i = 0; i < right.length; i++) {
    if (right[i] === "") continue;
    full.push(padHextet(right[i]));
  }

  if (full.length !== 8)
    return null;

  return full;
}

function arrayHas(arr, value) {
  for (var i = 0; i < arr.length; i++) {
    if (arr[i] === value)
      return true;
  }
  return false;
}

// ================= JORDAN IPv6 CHECK =================

function isJordanIPv6(ip) {
  var h = expandIPv6(ip);
  if (!h)
    return false;

  var key48 = h[0] + ":" + h[1] + ":" + h[2];
  var key44 = h[0] + ":" + h[1] + ":" + h[2].substring(0, 3);

  return arrayHas(JORDAN_IPV6_48, key48) || arrayHas(JORDAN_IPV6_44, key44);
}

// ================= REGION BLOCK =================

function isBlocked(ip) {
  ip = (ip || "").toLowerCase();

  return (
    ip.startsWith("240") ||
    ip.startsWith("241") ||
    ip.startsWith("242") ||
    ip.startsWith("2a05") ||
    ip.startsWith("2a06") ||
    ip.startsWith("2a0f") ||
    ip.startsWith("2c") ||
    ip.startsWith("260") ||
    ip.startsWith("280")
  );
}

// ================= PUBG DETECTION =================

function isPUBG(host) {
  host = (host || "").toLowerCase();

  return (
    host.indexOf("pubg") !== -1 ||
    host.indexOf("tencent") !== -1 ||
    host.indexOf("krafton") !== -1 ||
    host.indexOf("levelinfinite") !== -1 ||
    host.indexOf("lightspeed") !== -1
  );
}

// ================= LOBBY =================

function isLobby(data) {
  return /lobby|login|auth|session|gateway|queue|profile|inventory|store|shop|friends|party|team|update|patch|cdn|download/i.test(data);
}

// ================= MATCH =================

function isMatch(data) {
  return /match|battle|classic|ranked|arena|tdm|royale|war|payload|metro|zombie|gamesvr|relay|combat|survival|spectate/i.test(data);
}

// ================= NETWORK SEGMENTS =================

function getNet4(ip) {
  var h = expandIPv6(ip);
  if (!h) return "";
  return h.slice(0, 4).join(":");
}

function getNet5(ip) {
  var h = expandIPv6(ip);
  if (!h) return "";
  return h.slice(0, 5).join(":");
}

// ================= MAIN ENGINE =================

function FindProxyForURL(url, host) {
  if (isPlainHostName(host))
    return DIRECT;

  if (!isPUBG(host))
    return DIRECT;

  var ip = "";

  try {
    ip = dnsResolve(host);
  } catch (e) {
    ip = "";
  }

  if (!ip)
    return PROXY;

  if (isBlocked(ip))
    return BLOCK;

  // IPv4 ملغي بالكامل
  if (!isIPv6(ip))
    return BLOCK;

  // السماح فقط للنطاقات المحددة
  if (!isJordanIPv6(ip))
    return BLOCK;

  var data = (host + url).toLowerCase();
  var lobby = isLobby(data);
  var match = isMatch(data);

  var net4 = getNet4(ip);
  var net5 = getNet5(ip);

  if (!match && SESSION.active) {
    SESSION.match = null;
    SESSION.active = false;
  }

  if (lobby) {
    if (!SESSION.lobby)
      SESSION.lobby = net4;

    if (net4 !== SESSION.lobby)
      return BLOCK;

    return PROXY;
  }

  if (match) {
    if (!SESSION.match) {
      SESSION.match = net5;
      SESSION.active = true;
    }

    if (net5 !== SESSION.match)
      return BLOCK;

    return PROXY;
  }

  return PROXY;
}
